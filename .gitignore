# dependencies
node_modules/
**/node_modules/

# local database files (SQLite) — never commit patient data, even fake
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/*.sqlite

# build output
frontend/build/
dist/

# env / secrets
.env
*.env
!.env.example

# terraform state (can contain secrets)
terraform/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars

# logs and OS cruft
*.log
.DS_Store
Thumbs.db
